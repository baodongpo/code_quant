# ============================================================
# AI 量化辅助决策系统 - 环境配置模板
# 复制此文件为 .env 并填入实际值，.env 不提交仓库
# ============================================================

# 富途 OpenD 连接地址（本机运行时保持默认即可）
OPEND_HOST=127.0.0.1
OPEND_PORT=11111

# 数据库路径（可选，默认 data/quant.db）
# DB_PATH=/custom/path/to/quant.db

# 历史K线限频参数（可选，一般无需修改）
# RATE_LIMIT_MIN_INTERVAL=0.5
# RATE_LIMIT_WINDOW_SECONDS=30
# RATE_LIMIT_MAX_IN_WINDOW=25
# RATE_LIMIT_MAX_RETRIES=3

# 通用接口限频参数（日历/复权因子等，与K线限频器合计不超过 60次/30s）
# GENERAL_RATE_LIMIT_WINDOW_SECONDS=30
# GENERAL_RATE_LIMIT_MAX_IN_WINDOW=35

# 订阅额度（富途基础版约100只，按实际账户级别调整）
# MAX_SUBSCRIPTIONS=100

# 历史数据拉取起始日（与 design.md 保持一致）
# DEFAULT_HISTORY_START=2000-01-01

# 数据导出目录（默认 exports/）
# EXPORT_DIR=exports/

# 服务化配置（常驻进程模式）
# RECONNECT_MAX_RETRIES=5        # OpenD 断线最大重连次数
# RECONNECT_BASE_INTERVAL=30     # 断线重连基础间隔（秒，指数退避）
# HEALTH_CHECK_INTERVAL=60       # 健康检查文件写入间隔（秒）
# HEALTH_FILE=data/health.json   # 健康检查状态文件路径

# ============================================================
# Web 可视化服务配置（迭代3新增）
# ============================================================

# Web 服务运行模式
# development：启用 CORS，允许前端开发服务器（Vite）跨域访问
# production：关闭 CORS，后端直接 serve web/dist/ 前端构建产物
# WEB_MODE=development

# Web 服务端口（uvicorn 启动时传入，默认 8000）
# WEB_PORT=8000

# 允许跨域访问的前端地址（仅 development 模式有效）
# 多个地址用逗号分隔
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ============================================================
# 局域网访问 + Token 鉴权配置（迭代5新增）
# ============================================================

# uvicorn 绑定地址
# 127.0.0.1（默认）：仅本机访问
# 0.0.0.0：对局域网开放（需同时设置 WEB_ACCESS_TOKEN）
# WEB_HOST=127.0.0.1

# Web 访问 Token（留空则不启用鉴权）
# 局域网开放时强烈建议设置，例如：WEB_ACCESS_TOKEN=your-secret-token
# 访问方式：http://<ip>:<port>/?token=<your-secret-token>
# WEB_ACCESS_TOKEN=

# ============================================================
# yfinance 美股数据源配置（迭代9新增）
# ============================================================

# yfinance HTTP 代理地址
# - 国内访问 Yahoo Finance 需要非大陆IP的代理（翻墙代理），否则会被限频/阻断
# - 代理仅作用于 yfinance 请求（curl_cffi Session 级别），不影响富途 OpenD 等本地服务
# - 留空则不使用代理（直连，大陆网络环境可能无法正常使用）
# - 示例：YFINANCE_PROXY=http://127.0.0.1:7890（本地代理客户端地址）
# YFINANCE_PROXY=

# yfinance 请求间隔（秒），避免触发 Yahoo 限频
# - Yahoo 限频规则：60次/分钟、360次/小时、8000次/天（基于IP）
# - 代码已内置滑动窗口限频，此值为两次请求间的最小间隔
# - 个人非高频场景（每日同步几十只股票）默认 0.5s 即可
# YFINANCE_REQUEST_INTERVAL=0.5

# yfinance 请求最大重试次数
# - 普通错误：指数退避 1s→2s→4s
# - 429 限频错误：更长退避 30s→60s→120s
# YFINANCE_MAX_RETRIES=3

# 美股数据同步建议时间：
# - 推荐在北京时间 07:00（周二至周六）定时执行 sync 命令
# - 该时间兼容夏令时和冬令时，无需手动切换
# - 对应 crontab: 0 7 * * 2-6

# ============================================================
# TuShare 美股数据源配置（迭代10新增）
# ============================================================

# TuShare API Token
# - 注册地址：https://tushare.pro/register
# - 完善个人信息后可获得 120 积分，免费试用美股日线数据
# - 限制：50次/分钟、8000次/天
TUSHARE_TOKEN=

# TuShare 请求间隔（秒）
# - 120积分试用限制：50次/分钟，即 1.2秒/次
# - 默认值已适配试用限制，一般无需修改
# TUSHARE_REQUEST_INTERVAL=1.2

# 美股数据源选择
# - tushare：使用 TuShare（默认，推荐）
# - yfinance：已禁用（IP封禁严重）
US_STOCK_SOURCE=tushare

